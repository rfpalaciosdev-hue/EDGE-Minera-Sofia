# ================================================================
# AIM SCADA Edge — Variables de Entorno (TEMPLATE)
# Copiá este archivo como .env y completá los valores reales.
# NUNCA subas el .env al repositorio (ya está en .gitignore).
# Los valores reales viven en GitHub Secrets → Environment.
# ================================================================

# --- Identidad del sitio en la plataforma cloud ---
TENANT_SLUG=tu-tenant-aqui
SITE_ID=SITE_NOMBRE_PLANTA
DEVICE_TOKEN=token-generado-por-la-plataforma-al-crear-el-sitio

# --- URL del endpoint de sync en la nube (producción) ---
# Formato: https://{TENANT_SLUG}.aimdata.net/api/v1/tenant/edge/sync
CLOUD_API_URL=https://tu-tenant-aqui.aimdata.net/api/v1/tenant/edge/sync

# --- InfluxDB Local (buffer edge) ---
# Estos valores son usados internamente por los contenedores.
# Ponelos seguros pero no es necesario que sean ultra complejos.
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=cambiar-por-password-seguro
INFLUX_ORG=edge_planta
INFLUX_BUCKET=edge_buffer
INFLUX_TOKEN=token-largo-y-random-de-influxdb
